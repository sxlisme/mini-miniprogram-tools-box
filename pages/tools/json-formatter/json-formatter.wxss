page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  overflow-y: auto;
  background: #F5F5F5;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.clear-btn, .copy-btn {
  font-size: 24rpx;
  color: #4A7BEC;
  padding: 8rpx 16rpx;
  background: #EEF2FD;
  border-radius: 10rpx;
}

.copy-btn {
  min-width: 120rpx;
  text-align: center;
}

/* 输入框 */
.json-input {
  width: 100%;
  min-height: 260rpx;
  font-size: 26rpx;
  font-family: 'Courier New', monospace;
  color: #1A1A1A;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

/* 按钮组 */
.btn-group {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.btn-primary {
  background: linear-gradient(135deg, #4A7BEC, #3661CC);
  color: #FFFFFF;
}

.btn-outline {
  background: #FFFFFF;
  color: #4A7BEC;
  border: 2rpx solid #4A7BEC;
}

/* 缩进选项 */
.indent-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.indent-label {
  font-size: 26rpx;
  color: #666666;
}

.indent-options {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.indent-item {
  width: 64rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #666666;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.indent-item.active {
  background: #EEF2FD;
  color: #4A7BEC;
  border-color: #4A7BEC;
}

/* 错误 */
.error-box {
  background: #FFF0F0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
}

.error-text {
  font-size: 24rpx;
  color: #FF4D4F;
  line-height: 1.5;
}

/* 输出区 */
.json-output {
  background: #1E1E1E;
  border-radius: 12rpx;
  padding: 20rpx;
  max-height: 600rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.output-text {
  font-size: 24rpx;
  font-family: 'Courier New', monospace;
  color: #98C379;
  white-space: pre-wrap;
  word-break: break-all;
  line-height: 1.6;
}

.bottom-safe {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
