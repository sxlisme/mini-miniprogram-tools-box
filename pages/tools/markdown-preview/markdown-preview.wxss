page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  overflow-y: auto;
  background: #F5F5F5;
  padding: 0 24rpx;
  box-sizing: border-box;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  margin-top: 24rpx;
  background: #F0F0F0;
  border-radius: 14rpx;
  padding: 6rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.tab.active {
  background: #FFFFFF;
  color: #4A7BEC;
  font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}

/* Section */
.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.input-area {
  width: 100%;
  min-height: 300rpx;
  font-size: 26rpx;
  color: #333333;
  line-height: 1.8;
  background: #F8F8F8;
  border-radius: 14rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-family: Menlo, "Courier New", monospace;
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 12rpx;
  font-size: 24rpx;
  color: #999999;
  background: #F5F5F5;
  border-radius: 10rpx;
}

/* Preview */
.preview-section {
  min-height: 400rpx;
}

.empty-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #CCCCCC;
  margin-top: 20rpx;
}

.copy-btn {
  margin-top: 20rpx;
  padding: 14rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #4A7BEC;
  background: rgba(74, 123, 236, 0.08);
  border-radius: 12rpx;
  border: 1rpx solid rgba(74, 123, 236, 0.15);
}

.preview-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  word-break: break-all;
}

.bottom-safe {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
