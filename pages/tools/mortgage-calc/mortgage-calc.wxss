page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  overflow-y: auto;
  background: #F5F5F5;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 20rpx;
}

/* 输入组 */
.input-group {
  margin-bottom: 24rpx;
}

.input-group:last-child {
  margin-bottom: 0;
}

.input-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: block;
}

.input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #F8F8F8;
  border-radius: 14rpx;
  padding: 0 20rpx;
  height: 80rpx;
  box-sizing: border-box;
}

.input-prefix, .input-suffix {
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #1A1A1A;
  text-align: center;
}

/* 还款方式 */
.method-wrap {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.method-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #666666;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.method-item.active {
  background: #EEF2FD;
  color: #4A7BEC;
  border-color: #4A7BEC;
}

/* 计算按钮 */
.btn-wrap {
  padding: 32rpx 0;
}

.calc-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4A7BEC, #3661CC);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: none;
}

.calc-btn::after {
  border: none;
}

/* 结果卡片 */
.result-card {
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 8rpx 0;
  overflow: hidden;
  box-sizing: border-box;
}

.result-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #EEEEEE;
  box-sizing: border-box;
}

.result-item:last-child {
  border-bottom: none;
}

.result-item.highlight {
  background: linear-gradient(135deg, #EEF2FD, #DCE3FA);
}

.result-label {
  font-size: 26rpx;
  color: #666666;
}

.result-value {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.result-value.big {
  font-size: 36rpx;
  color: #4A7BEC;
  font-weight: 700;
}

.bottom-safe {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
