page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  overflow-y: auto;
  background: #F5F5F5;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 20rpx;
}

.input-area {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  background: #F8F8F8;
  border-radius: 14rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 12rpx;
  font-size: 24rpx;
  color: #999999;
  background: #F5F5F5;
  border-radius: 10rpx;
}

/* Stats Grid */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stat-item {
  width: calc(25% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: #EEF2FD;
  border-radius: 14rpx;
  box-sizing: border-box;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A7BEC;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: #666666;
  margin-top: 8rpx;
}

.bottom-safe {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
