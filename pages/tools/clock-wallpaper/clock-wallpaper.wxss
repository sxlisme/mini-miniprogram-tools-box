/* 页面根元素：flex 列布局，导航栏 + 内容区 */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  overflow-y: auto;
  box-sizing: border-box;
  background: #f5f5f5;
}

/* ===== 缩略图画廊 ===== */
.gallery {
  width: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.gallery-header {
  text-align: center;
  padding: 16rpx 0 24rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #999;
}

/* 缩略图网格 */
.thumbnail-grid {
  display: flex;
  flex-wrap: wrap;
}

.thumb-item {
  width: calc((100vw - 80rpx) / 3);
  height: calc((100vw - 80rpx) / 3);
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: #000;
}

/* 每行第3个去掉右边距 */
.thumb-item:nth-child(3n) {
  margin-right: 0;
}

.thumb-img {
  display: block;
  width: 100%;
  height: 100%;
}

/* 用户壁纸标签 */
.thumb-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: rgba(102, 126, 234, 0.85);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  pointer-events: none;
}

/* 删除按钮 */
.thumb-delete {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 添加按钮 */
.thumb-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 2rpx dashed #ccc;
}

.add-icon {
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 22rpx;
  color: #999;
}

/* 底部提示 */
.gallery-tip {
  text-align: center;
  padding: 24rpx 0 40rpx;
  font-size: 24rpx;
  color: #bbb;
}

/* ===== 全屏覆盖层 ===== */
.fullscreen-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 9999;
  background: #000;
  pointer-events: auto;
}

.fullscreen-image {
  width: 100vw;
  height: 100vh;
}

.hint-text {
  position: fixed;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.6);
  font-size: 26rpx;
  z-index: 10000;
  pointer-events: none;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
  opacity: 1;
  transition: opacity 0.5s;
}

.hint-text.visible {
  opacity: 1;
}

.hint-text.hidden {
  opacity: 0;
}
