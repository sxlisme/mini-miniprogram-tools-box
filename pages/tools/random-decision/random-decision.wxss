page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  overflow-y: auto;
  background: #F5F5F5;
  padding: 0 24rpx;
  box-sizing: border-box;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  margin-top: 24rpx;
  background: #F0F0F0;
  border-radius: 14rpx;
  padding: 6rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 10rpx;
}

.tab.active {
  background: #FFFFFF;
  color: #4A7BEC;
  font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}

.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

/* 骰子 */
.dice-area {
  text-align: center;
}

.dice-count {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.slider-wrap {
  padding: 0 8rpx;
}

.dice-results {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.dice-item {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #4A7BEC;
  background: #EEF2FD;
  border-radius: 16rpx;
  transition: all 0.1s;
}

.dice-item.rolling {
  animation: shake 0.15s infinite;
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}

.dice-sum {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A7BEC;
  margin-top: 16rpx;
}

/* 硬币 */
.coin-area {
  text-align: center;
  padding: 40rpx 0;
}

.coin-result {
  font-size: 80rpx;
  line-height: 1.2;
}

.coin-result.coin-flip {
  animation: flip 0.15s infinite;
}

@keyframes flip {
  0% { transform: rotateY(0deg); }
  50% { transform: rotateY(90deg); }
  100% { transform: rotateY(0deg); }
}

.coin-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 自定义 */
.input-area {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  background: #F8F8F8;
  border-radius: 14rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.custom-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: right;
}

.custom-result {
  margin-top: 24rpx;
  padding: 28rpx;
  background: #EEF2FD;
  border-radius: 14rpx;
  text-align: center;
}

.custom-result-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.custom-result-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #4A7BEC;
  word-break: break-all;
}

/* 转盘 */
.wheel-input-wrap {
  margin-bottom: 20rpx;
}

.wheel-textarea {
  width: 100%;
  min-height: 72rpx;
  max-height: 180rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
  box-sizing: border-box;
}

.wheel-input-hint {
  font-size: 22rpx;
  color: #999;
  text-align: right;
  margin-top: 8rpx;
}

.wheel-container {
  position: relative;
  width: 500rpx;
  height: 500rpx;
  margin: 20rpx auto 0;
}

.wheel-pointer {
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 44rpx;
  color: #E74C3C;
  z-index: 10;
  line-height: 1;
  filter: drop-shadow(0 2rpx 4rpx rgba(0,0,0,0.15));
}

.wheel-canvas {
  width: 100%;
  height: 100%;
}

.wheel-center-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 104rpx;
  height: 104rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #F0F0F0;
  z-index: 10;
}

.wheel-btn-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #E74C3C;
  line-height: 1;
}

.wheel-result {
  margin-top: 32rpx;
  padding: 28rpx;
  background: #EEF2FD;
  border-radius: 16rpx;
  text-align: center;
}

.wheel-result-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.wheel-result-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #4A7BEC;
}

/* 操作按钮 */
.action-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 28rpx;
  background: linear-gradient(135deg, #4A7BEC, #3661CC);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.action-btn::after { border: none; }

.hint {
  font-size: 24rpx;
  color: #CCC;
  text-align: center;
  margin-top: 28rpx;
}

.bottom-safe {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
