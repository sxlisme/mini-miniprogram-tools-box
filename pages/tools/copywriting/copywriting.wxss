page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  overflow-y: auto;
  background: #F5F5F5;
  padding: 0 24rpx;
  box-sizing: border-box;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  margin-top: 24rpx;
  background: #F0F0F0;
  border-radius: 14rpx;
  padding: 6rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 10rpx;
}

.tab.active {
  background: #FFFFFF;
  color: #4A7BEC;
  font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}

/* 列表 */
.list {
  margin-top: 24rpx;
}

/* 卡片 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-index {
  font-size: 22rpx;
  color: #BBB;
}

.card-actions {
  display: flex;
  gap: 12rpx;
}

.copy-btn {
  font-size: 22rpx;
  color: #4A7BEC;
  padding: 8rpx 20rpx;
  background: #EEF2FD;
  border-radius: 20rpx;
  font-weight: 500;
}

/* 封面文案 */
.card-cover {
  font-size: 24rpx;
  color: #4A7BEC;
  background: #EEF2FD;
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* 标题 */
.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.title-char-count {
  font-size: 24rpx;
  font-weight: 400;
  color: #BBB;
  margin-left: 8rpx;
  white-space: nowrap;
  display: inline;
}

/* 正文 */
.card-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
  letter-spacing: 1rpx;
}

/* 金句 */
.card-quote {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #FFFBF0;
  border-left: 4rpx solid #F39C12;
  border-radius: 0 10rpx 10rpx 0;
  font-size: 26rpx;
  color: #B07A0A;
  line-height: 1.7;
}

.quote-mark {
  font-size: 44rpx;
  color: #F39C12;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 4rpx;
}

/* 互动 */
.card-interaction {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #F8F8F8;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
}

.interaction-label {
  font-size: 26rpx;
}

/* 标签 */
.card-tags {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 22rpx;
  color: #4A7BEC;
  background: #EEF2FD;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 已复制标记 */
.card.copied {
  opacity: 0.45;
}

/* 底部 */
.bottom-safe {
  height: calc(110rpx + env(safe-area-inset-bottom));
}
