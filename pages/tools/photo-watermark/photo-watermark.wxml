<navigation-bar title="照片水印" back="{{true}}" color="black" background="#FFF"></navigation-bar>

<scroll-view class="page" scroll-y enhanced show-scrollbar="{{false}}">
  <!-- 预览区 -->
  <view class="section preview-section">
    <view class="section-header">
      <text class="section-title">预览</text>
      <text class="rechoose-btn" wx:if="{{hasImage}}" bindtap="reChooseImage">换图</text>
    </view>
    <view class="canvas-wrap" bindtap="{{hasImage ? '' : 'chooseImage'}}">
      <!-- 实时预览 Canvas -->
      <canvas
        wx:if="{{hasImage}}"
        type="2d"
        id="watermarkCanvas"
        class="preview-canvas"
        style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
      ></canvas>
      <!-- 占位 -->
      <view wx:else class="placeholder">
        <t-icon class="placeholder-icon" name="camera" size="80rpx" color="#CCCCCC" />
        <text class="placeholder-text">点击选择照片</text>
      </view>
    </view>
  </view>

  <!-- 水印设置 -->
  <view class="section" wx:if="{{hasImage}}">
    <view class="section-title">水印设置</view>

    <!-- 文字输入 -->
    <view class="control-row">
      <text class="control-label">水印文字</text>
      <view class="input-wrap">
        <input
          class="control-input {{textCheckPassed ? '' : 'input-warn'}}"
          placeholder="仅限XX使用 他用无效"
          value="{{watermarkText}}"
          bindinput="onTextInput"
        />
        <t-icon wx:if="{{watermarkText}}" class="input-clear" name="close" size="28rpx" bindtap="onClearText" />
      </view>
    </view>
    <!-- 文本安全警告 -->
    <view class="safety-warn" wx:if="{{!textCheckPassed && watermarkText}}">
      <text class="safety-warn-text"><t-icon name="error-circle" size="28rpx" /> 文字包含违规内容，请修改后再保存</text>
    </view>

    <!-- 水印模式 -->
    <view class="control-row">
      <text class="control-label">水印模式</text>
      <view class="radio-wrap">
        <view class="radio-item" data-mode="tile" bindtap="onModeChange">
          <view class="radio-dot {{mode === 'tile' ? 'checked' : ''}}"></view>
          <text>平铺</text>
        </view>
        <view class="radio-item" data-mode="single" bindtap="onModeChange">
          <view class="radio-dot {{mode === 'single' ? 'checked' : ''}}"></view>
          <text>单个</text>
        </view>
      </view>
    </view>

    <!-- 颜色选择 -->
    <view class="control-row">
      <text class="control-label">文字颜色</text>
      <view class="color-picker-wrap">
        <view
          class="color-dot {{textColor === item ? 'selected' : ''}}"
          wx:for="{{['#FFFFFF','#000000','#FF0000','#FF6600','#FFD700','#07C160','#1E90FF','#8B00FF']}}"
          wx:key="*this"
          style="background: {{item}};"
          data-color="{{item}}"
          bindtap="onColorPick"
        ></view>
        <input
          class="color-input"
          type="text"
          value="{{textColor}}"
          bindinput="onColorChange"
          placeholder="#FFFFFF"
        />
      </view>
    </view>

    <!-- 文字大小 -->
    <view class="control-row">
      <text class="control-label">文字大小</text>
      <view class="slider-wrap">
        <slider
          min="16"
          max="100"
          value="{{textSize}}"
          bindchange="onSizeChange"
          activeColor="#07C160"
          block-size="20"
        />
        <text class="slider-val">{{textSize}}px</text>
      </view>
    </view>

    <!-- 透明度 -->
    <view class="control-row">
      <text class="control-label">透明度</text>
      <view class="slider-wrap">
        <slider
          min="10"
          max="100"
          value="{{textOpacity}}"
          bindchange="onOpacityChange"
          activeColor="#07C160"
          block-size="20"
        />
        <text class="slider-val">{{textOpacity}}%</text>
      </view>
    </view>

    <!-- 旋转角度 -->
    <view class="control-row">
      <text class="control-label">旋转角度</text>
      <view class="slider-wrap">
        <slider
          min="-60"
          max="60"
          value="{{rotation}}"
          bindchange="onRotationChange"
          activeColor="#07C160"
          block-size="20"
        />
        <text class="slider-val">{{rotation}}°</text>
      </view>
    </view>

    <!-- 平铺间距（仅平铺模式） -->
    <block wx:if="{{mode === 'tile'}}">
      <view class="control-row">
        <text class="control-label">水平间距</text>
        <view class="slider-wrap">
          <slider
            min="80"
            max="400"
            value="{{tileSpacingX}}"
            bindchange="onSpacingXChange"
            activeColor="#07C160"
            block-size="20"
          />
          <text class="slider-val">{{tileSpacingX}}</text>
        </view>
      </view>
      <view class="control-row">
        <text class="control-label">垂直间距</text>
        <view class="slider-wrap">
          <slider
            min="60"
            max="400"
            value="{{tileSpacingY}}"
            bindchange="onSpacingYChange"
            activeColor="#07C160"
            block-size="20"
          />
          <text class="slider-val">{{tileSpacingY}}</text>
        </view>
      </view>
    </block>

    <!-- 位置选择（仅单个模式） -->
    <block wx:if="{{mode === 'single'}}">
      <view class="control-row">
        <text class="control-label">水印位置</text>
      </view>
      <view class="pos-grid">
        <view
          class="pos-item {{textPosition === item ? 'active' : ''}}"
          wx:for="{{['topLeft','topRight','bottomLeft','bottomRight']}}"
          wx:key="*this"
          wx:for-item="item"
          data-pos="{{item}}"
          bindtap="onPositionChange"
        >
          <text>{{item === 'topLeft' ? '左上' : item === 'topRight' ? '右上' : item === 'bottomLeft' ? '左下' : '右下'}}</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 保存按钮 -->
  <view class="save-btn-wrap" wx:if="{{hasImage && watermarkText && textCheckPassed}}">
    <button class="save-btn" bindtap="saveImage">
      <t-icon name="download" size="28rpx" /> 保存到相册
    </button>
  </view>
  <view class="save-btn-wrap" wx:if="{{hasImage && watermarkText && !textCheckPassed}}">
    <button class="save-btn save-btn-disabled" disabled>
      <t-icon name="error-circle" size="28rpx" /> 请修改违规文字
    </button>
  </view>

  <!-- 检测中 -->
  <view class="checking-overlay" wx:if="{{checking}}">
    <view class="checking-box">
      <view class="checking-spinner"></view>
      <text class="checking-text">安全检测中...</text>
    </view>
  </view>

  <view class="bottom-safe"></view>
</scroll-view>