page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  overflow-y: auto;
  background: #F5F5F5;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.preview-section {
  padding-bottom: 20rpx;
}

.section-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.rechoose-btn {
  font-size: 24rpx;
  color: #4A7BEC;
  padding: 8rpx 20rpx;
  background: #EEF2FD;
  border-radius: 10rpx;
}

/* Canvas 预览区 */
.canvas-wrap {
  width: 100%;
  min-height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.preview-canvas {
  display: block;
  max-width: 100%;
  border-radius: 12rpx;
}

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  width: 100%;
}

.placeholder-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.placeholder-text {
  font-size: 26rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 控制行 */
.control-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
  box-sizing: border-box;
}

.control-label {
  font-size: 26rpx;
  color: #333333;
  flex-shrink: 0;
  width: 130rpx;
  box-sizing: border-box;
}

/* 输入区域 */
.input-wrap {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  position: relative;
}

.control-input {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  height: 56rpx;
  padding-right: 48rpx;
  box-sizing: border-box;
}

.input-clear {
  position: absolute;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #DDDDDD;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* 文本安全警告 */
.safety-warn {
  padding: 14rpx 16rpx;
  margin-top: 8rpx;
  background: #FFF3F0;
  border-radius: 10rpx;
  border: 1rpx solid #FFCCC7;
  box-sizing: border-box;
}

.safety-warn-text {
  font-size: 24rpx;
  color: #FF4D4F;
}

.input-warn {
  color: #FF4D4F;
}

/* Radio 模式选择 */
.radio-wrap {
  flex: 1;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  gap: 32rpx;
}

.radio-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #333333;
}

.radio-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 3rpx solid #CCCCCC;
  box-sizing: border-box;
  transition: all 0.15s;
}

.radio-dot.checked {
  border-color: #4A7BEC;
  border-width: 10rpx;
}

/* 颜色选择 */
.color-picker-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.color-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-left: 12rpx;
  border: 3rpx solid transparent;
  box-sizing: border-box;
  transition: transform 0.15s;
}

.color-dot.selected {
  border-color: #4A7BEC;
  transform: scale(1.25);
}

.color-input {
  width: 130rpx;
  height: 48rpx;
  font-size: 22rpx;
  margin-left: 16rpx;
  text-align: center;
  border: 1rpx solid #E5E5E5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

/* 滑块 */
.slider-wrap {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.slider-wrap slider {
  flex: 1;
}

.slider-val {
  font-size: 24rpx;
  color: #666666;
  margin-left: 16rpx;
  min-width: 90rpx;
  text-align: right;
}

/* 位置网格 */
.pos-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.pos-item {
  width: calc(50% - 8rpx);
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 14rpx;
  font-size: 24rpx;
  color: #666666;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  transition: all 0.15s;
}

.pos-item.active {
  background: #EEF2FD;
  color: #4A7BEC;
  border-color: #4A7BEC;
}

/* 保存按钮 */
.save-btn-wrap {
  padding: 32rpx 0;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4A7BEC, #3661CC);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn-disabled {
  background: #CCCCCC;
  background-image: none;
}

/* 安全检测中 */
.checking-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35);
  display: flex; align-items: center; justify-content: center;
  z-index: 9999;
}
.checking-box {
  background: #FFF; border-radius: 20rpx; padding: 48rpx 60rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
}
.checking-spinner {
  width: 56rpx; height: 56rpx;
  border: 5rpx solid #F0F0F0; border-top-color: #4A7BEC;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.checking-text { font-size: 28rpx; color: #666; margin-top: 24rpx; }

.bottom-safe {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
