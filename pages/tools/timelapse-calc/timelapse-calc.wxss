page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  box-sizing: border-box;
  background: #F5F5F5;
  padding: 0 24rpx;
}

/* 模式切换 tabs */
.mode-tabs {
  display: flex;
  flex-direction: row;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.mode-tab {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999999;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.mode-tab.active {
  background: #4A7BEC;
  color: #FFFFFF;
  font-weight: 600;
}

/* Section */
.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 20rpx;
}

/* Input row */
.input-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.input-group {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  margin-right: 16rpx;
  box-sizing: border-box;
}

.input-group:last-child {
  margin-right: 0;
}

.input-label {
  font-size: 26rpx;
  color: #999999;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.num-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  text-align: center;
  background: transparent;
  min-height: 60rpx;
  line-height: 60rpx;
}

.full-input {
  flex: 1;
  margin-right: 12rpx;
  border-radius: 16rpx;
  background: #F8F8F8;
  padding: 12rpx 20rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  text-align: center;
  min-height: 60rpx;
}

.input-suffix {
  font-size: 26rpx;
  color: #999999;
  flex-shrink: 0;
}

/* FPS chips */
.fps-options {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.fps-chip {
  flex: 1;
  min-width: 140rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.2s;
}

.fps-chip.active {
  background: #EEF2FD;
  color: #4A7BEC;
  font-weight: 600;
}

/* Presets */
.preset-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preset-chip {
  flex: 1;
  min-width: calc(50% - 12rpx);
  height: 72rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  transition: all 0.15s;
}

.preset-chip:active {
  background: #EEF2FD;
  transform: scale(0.96);
}

.preset-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.preset-text {
  font-size: 22rpx;
  color: #666666;
  text-align: center;
}

/* Result card */
.result-card {
  background: linear-gradient(135deg, #4A7BEC 0%, #3661CC 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(74, 123, 236, 0.3);
}

.result-item.primary {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-value-row {
  margin-top: 12rpx;
}

.result-value {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.result-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.25);
  margin-bottom: 20rpx;
}

.result-cols {
  display: flex;
  flex-direction: row;
}

.result-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 6rpx;
}

.result-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.copy-btn {
  margin-top: 24rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #FFFFFF;
  transition: background 0.15s;
}

.copy-btn:active {
  background: rgba(255, 255, 255, 0.35);
}

/* Bottom safe */
.bottom-safe {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
