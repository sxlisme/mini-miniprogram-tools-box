page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  overflow-y: auto;
  background: #F5F5F5;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.copy-all-btn {
  font-size: 24rpx;
  color: #4A7BEC;
  padding: 8rpx 16rpx;
  background: #EEF2FD;
  border-radius: 8rpx;
}

/* UUID 展示 */
.uuid-display {
  text-align: center;
  padding: 24rpx 0;
}

.uuid-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A7BEC;
  font-family: Menlo, "Courier New", monospace;
  word-break: break-all;
  line-height: 1.6;
}

.uuid-meta {
  font-size: 22rpx;
  color: #CCC;
  margin-top: 12rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #CCCCCC;
  margin-top: 16rpx;
}

/* 按钮 */
.btn-row {
  display: flex;
  gap: 16rpx;
}

.gen-btn {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #4A7BEC, #3661CC);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.gen-btn::after { border: none; }

.outline-btn {
  flex: 1;
  height: 80rpx;
  background: #FFFFFF;
  color: #4A7BEC;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #4A7BEC;
}
.outline-btn::after { border: none; }

/* 批量 */
.count-row {
  margin-top: 24rpx;
}

.count-label {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 8rpx;
}

.slider-wrap {
  padding: 0 8rpx;
}

/* 历史 */
.history-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-index {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999;
  background: #F5F5F5;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.history-text {
  flex: 1;
  font-size: 22rpx;
  color: #666;
  font-family: Menlo, "Courier New", monospace;
  word-break: break-all;
  line-height: 1.5;
}

.history-copy {
  flex-shrink: 0;
  padding: 8rpx;
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 20rpx;
  padding: 12rpx;
  font-size: 24rpx;
  color: #999;
  background: #F5F5F5;
  border-radius: 10rpx;
}

.bottom-safe {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
