page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  overflow-y: auto;
  background: #F5F5F5;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 20rpx;
}

/* 日期行 */
.date-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.date-box {
  flex: 1;
}

.date-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 10rpx;
  display: block;
}

.date-picker {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: #F8F8F8;
  border-radius: 14rpx;
  padding: 0 20rpx;
  height: 80rpx;
  box-sizing: border-box;
}

.date-text {
  font-size: 28rpx;
  color: #1A1A1A;
}

.date-arrow {
  font-size: 32rpx;
}

.date-divider {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 12rpx;
  margin-top: 28rpx;
}

.divider-line {
  width: 20rpx;
  height: 2rpx;
  background: #DDDDDD;
}

.divider-arrow {
  font-size: 28rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 开关行 */
.toggle-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.toggle-label {
  font-size: 26rpx;
  color: #333333;
}

/* 计算按钮 */
.btn-wrap {
  padding: 32rpx 0;
}

.calc-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4A7BEC, #3661CC);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: none;
}

.calc-btn::after {
  border: none;
}

/* 结果区 */
.result-card {
  text-align: center;
}

.result-main {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: center;
  padding: 20rpx 0;
}

.result-big-num {
  font-size: 80rpx;
  font-weight: 700;
  color: #4A7BEC;
  line-height: 1;
}

.result-unit {
  font-size: 36rpx;
  color: #666666;
  margin-left: 8rpx;
}

.result-dir {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.result-breakdown {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 40rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #F0F0F0;
}

.break-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.break-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.break-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.result-extra {
  border-top: 1rpx solid #F0F0F0;
  padding-top: 20rpx;
  margin-top: 8rpx;
}

.extra-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.extra-label {
  font-size: 26rpx;
  color: #666666;
}

.extra-value {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.bottom-safe {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
