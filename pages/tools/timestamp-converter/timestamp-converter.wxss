page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  overflow-y: auto;
  background: #F5F5F5;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 20rpx;
}

/* 当前时间戳 */
.now-row {
  display: flex;
  gap: 20rpx;
}

.now-item {
  flex: 1;
  background: #EEF2FD;
  border-radius: 14rpx;
  padding: 20rpx;
  text-align: center;
}

.now-val {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A7BEC;
  word-break: break-all;
}

.now-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.now-time {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-top: 16rpx;
}

.refresh-btn {
  width: 100%;
  height: 72rpx;
  margin-top: 16rpx;
  background: linear-gradient(135deg, #4A7BEC, #3661CC);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.refresh-btn::after { border: none; }

/* 时间戳 → 日期 */
.input-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.ts-input {
  flex: 1;
  height: 80rpx;
  background: #F8F8F8;
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.unit-tabs {
  display: flex;
  background: #F0F0F0;
  border-radius: 14rpx;
  padding: 4rpx;
}

.unit {
  padding: 14rpx 20rpx;
  font-size: 26rpx;
  color: #999;
  border-radius: 10rpx;
}

.unit.active {
  background: #4A7BEC;
  color: #FFF;
  font-weight: 600;
}

/* 日期 → 时间戳 */
.picker-row {
  display: flex;
  gap: 16rpx;
}

.picker-display {
  flex: 1;
  height: 80rpx;
  background: #F8F8F8;
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.now-set-btn {
  width: 100%;
  height: 72rpx;
  margin-top: 16rpx;
  background: #EEF2FD;
  color: #4A7BEC;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.now-set-btn::after { border: none; }

/* 复制按钮 */
.copy-one {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #4A7BEC;
  text-align: center;
  padding: 8rpx 0;
  border-radius: 8rpx;
  background: rgba(74, 123, 236, 0.1);
}

/* 结果 */
.result-box {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #EEF2FD;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #4A7BEC;
  font-weight: 600;
  text-align: center;
  word-break: break-all;
}

.result-text {
  display: block;
}

.error-box {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #FFF0F0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #FF4D4F;
  text-align: center;
}

.bottom-safe {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
