<navigation-bar title="我的收藏" back="{{false}}" color="black" background="#FFF"></navigation-bar>

<view class="page">
  <!-- 空状态 -->
  <view wx:if="{{favorites.length === 0}}" class="empty-state">
    <t-icon class="empty-icon" name="star" size="96rpx" color="#CCCCCC" />
    <text class="empty-text">还没有收藏任何工具</text>
    <text class="empty-hint">去首页浏览并收藏常用工具吧</text>
  </view>

  <!-- 收藏列表 -->
  <scroll-view wx:else class="scroll-area" scroll-y enhanced show-scrollbar="{{false}}">
    <view
      class="fav-item"
      wx:for="{{favorites}}"
      wx:key="id"
      bindtap="openTool"
      data-tool="{{item}}"
    >
      <view class="fav-icon-wrap" style="background: {{item.color}};">
        <t-icon class="fav-icon" name="{{item.icon}}" size="40rpx" color="#FFFFFF" />
      </view>
      <view class="fav-body">
        <text class="fav-name">{{item.name}}</text>
        <text class="fav-desc">{{item.desc}}</text>
      </view>
      <view class="fav-action" catchtap="removeFav" data-id="{{item.id}}">
        <text class="fav-del">取消</text>
      </view>
    </view>
    <view class="bottom-safe"></view>
  </scroll-view>
</view>