page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #F5F5F5;
  box-sizing: border-box;
}

.scroll-area {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 收藏项 */
.fav-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.fav-item:active {
  background: #F8F8F8;
}

.fav-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

.fav-icon {
}

.fav-body {
  flex: 1;
  margin-left: 24rpx;
  margin-right: 16rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.fav-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 6rpx;
}

.fav-desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fav-action {
  flex-shrink: 0;
}

.fav-del {
  font-size: 24rpx;
  color: #FF6B6B;
  padding: 12rpx 20rpx;
  background: #FFF0F0;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.bottom-safe {
  height: calc(110rpx + env(safe-area-inset-bottom));
}
