page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

/* 头部 */
.header {
  padding: 40rpx 32rpx 24rpx;
  background: linear-gradient(135deg, #4A7BEC 0%, #3661CC 100%);
  box-sizing: border-box;
}

.header-greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.header-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 滚动区 */
.scroll-area {
  flex: 1;
  padding: 0 24rpx;
  box-sizing: border-box;
}

/* 工具网格 */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding-top: 24rpx;
  box-sizing: border-box;
}

.tool-card {
  width: calc(50% - 12rpx);
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 24rpx 24rpx;
  margin-bottom: 24rpx;
  position: relative;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s;
}

.tool-card:active {
  transform: scale(0.96);
}

/* 图标 */
.card-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.card-icon {
}

/* 文字 */
.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 6rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #999999;
  display: block;
  line-height: 1.4;
}

/* 收藏按钮 */
.card-fav {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 底部安全距离 */
.bottom-safe {
  height: 40rpx;
}
