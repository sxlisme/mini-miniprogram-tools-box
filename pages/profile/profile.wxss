page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #F5F5F5;
  box-sizing: border-box;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #4A7BEC 0%, #3661CC 100%);
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

.user-card .avatar-btn {
  width: 120rpx !important;
  height: 120rpx !important;
  min-width: 120rpx !important;
  max-width: 120rpx !important;
  min-height: 120rpx !important;
  max-height: 120rpx !important;
  border-radius: 50%;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.4);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  box-sizing: border-box;
  background: transparent !important;
  line-height: 1 !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-icon {
}

.avatar-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #FFFFFF;
}

.user-info {
  margin-left: 28rpx;
  flex: 1;
  box-sizing: border-box;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.edit-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-top: 6rpx;
}

/* 滚动区 */
.scroll-area {
  flex: 1;
  box-sizing: border-box;
}

/* 区块 */
.section {
  background: #FFFFFF;
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 26rpx;
  color: #999999;
  padding: 24rpx 0 16rpx;
  box-sizing: border-box;
}

.info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  box-sizing: border-box;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #333333;
}

.info-value {
  font-size: 26rpx;
  color: #666666;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 登录记录 */
.empty-login {
  padding: 20rpx 0 24rpx;
  font-size: 26rpx;
  color: #CCCCCC;
  text-align: center;
  box-sizing: border-box;
}

.log-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
}

.log-dot {
  margin-right: 16rpx;
}

.log-time {
  font-size: 24rpx;
  color: #666666;
}

/* 操作行 */
.action-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  box-sizing: border-box;
}

.action-text {
  font-size: 28rpx;
  color: #333333;
}

.action-text.danger {
  color: #FF6B6B;
}

.action-arrow {
}

/* 底部 */
.footer {
  padding: 40rpx 0;
  text-align: center;
  box-sizing: border-box;
}

.footer-text {
  font-size: 22rpx;
  color: #CCCCCC;
}

.bottom-safe {
  height: calc(110rpx + env(safe-area-inset-bottom));
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 28rpx;
  z-index: 201;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-input {
  height: 80rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  flex-direction: row;
  margin-top: 32rpx;
  box-sizing: border-box;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-btn.cancel {
  background: #F5F5F5;
  color: #666666;
  margin-right: 20rpx;
}

.modal-btn.confirm {
  background: #4A7BEC;
  color: #FFFFFF;
}
